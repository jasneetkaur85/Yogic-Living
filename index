<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Yogic Living</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { font-family: 'Open Sans', sans-serif; background:#fdfcf7; color:#333; }
    h2 { color:#2e6d4f; margin-bottom:20px; }
    .navbar-brand { font-family:'Playfair Display', serif; font-weight:bold; color:#2e6d4f; }
    .service-card { border:none; box-shadow:0 2px 6px rgba(0,0,0,0.1); border-radius:8px; }
    .instructor-card img { border-radius:50%; width:120px; height:120px; object-fit:cover; }
    footer { background:#2e6d4f; color:#fff; padding:20px 0; }
  </style>
</head>
<body>

<!-- Navigation -->
<nav class="navbar navbar-expand-lg navbar-light shadow-sm">
  <div class="container">
    <a class="navbar-brand" href="#">Yogic Living</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navMenu">
      <ul class="navbar-nav ms-auto">
        <li class="nav-item"><a class="nav-link" href="#about">About</a></li>
        <li class="nav-item"><a class="nav-link" href="#services">Services</a></li>
        <li class="nav-item"><a class="nav-link" href="#retreats">Retreats</a></li>
        <li class="nav-item"><a class="nav-link" href="#instructors">Instructors</a></li>
        <li class="nav-item"><a class="nav-link" href="#contact">Contact</a></li>
      </ul>
    </div>
  </div>
</nav>

<!-- Carousel -->
<div id="homeCarousel" class="carousel slide" data-bs-ride="carousel">
  <div class="carousel-inner">
    <div class="carousel-item active">
      <img src="banner1.jpg" class="d-block w-100" alt="Personalized Yoga">
      <div class="carousel-caption"><h3>Personalized Yoga</h3><p>One-on-one sessions tailored to your journey.</p></div>
    </div>
    <div class="carousel-item">
      <img src="banner2.jpg" class="d-block w-100" alt="Corporate Yoga">
      <div class="carousel-caption"><h3>Corporate Wellness</h3><p>Stress management and balance at work.</p></div>
    </div>
    <div class="carousel-item">
      <img src="banner3.jpg" class="d-block w-100" alt="Yoga Retreats">
      <div class="carousel-caption"><h3>Nature Retreats</h3><p>Reconnect with yourself in serene settings.</p></div>
    </div>
    <div class="carousel-item">
      <img src="banner4.jpg" class="d-block w-100" alt="Spiritual Journey">
      <div class="carousel-caption"><h3>Spiritual Journey</h3><p>From asana to samadhi.</p></div>
    </div>
  </div>
</div>

<!-- About -->
<section id="about" class="container text-center my-5">
  <h2>About Us</h2>
  <p>At Yogic Living, we guide individuals, groups, and organizations toward equilibrium through authentic yogic practices. Our instructors are certified by Yoga Alliance RYT and Morarji Desai National Institute of Yoga.</p>
</section>

<!-- Services Preview -->
<section id="services" class="container my-5">
  <h2>Our Services</h2>
  <div class="row g-4">
    <div class="col-md-3"><div class="card service-card p-3"><h5>Personalized Yoga</h5><p>Tailored one-on-one sessions.</p></div></div>
    <div class="col-md-3"><div class="card service-card p-3"><h5>Group Classes</h5><p>Community practice fostering connection.</p></div></div>
    <div class="col-md-3"><div class="card service-card p-3"><h5>Corporate Yoga</h5><p>Mindfulness and stress management at work.</p></div></div>
    <div class="col-md-3"><div class="card service-card p-3"><h5>Retreats</h5><p>Immersive experiences in nature-friendly zones.</p></div></div>
  </div>
</section>

<!-- Retreats -->
<section id="retreats" class="container my-5">
  <h2>Retreats & Workshops</h2>
  <p>Join us for transformative retreats and workshops including mantra chanting, sound healing, and mindfulness practices.</p>
</section>

<!-- Instructors -->
<section id="instructors" class="container my-5">
  <h2>Our Instructors</h2>
  <div class="row g-4">
    <div class="col-md-4 text-center instructor-card">
      <img src="guru1.jpg" alt="Instructor 1">
      <h5>Guru Name</h5>
      <p>RYT Yoga Alliance Certified</p>
    </div>
    <div class="col-md-4 text-center instructor-card">
      <img src="guru2.jpg" alt="Instructor 2">
      <h5>Guru Name</h5>
      <p>Morarji Desai National Institute Graduate</p>
    </div>
    <div class="col-md-4 text-center instructor-card">
      <img src="guru3.jpg" alt="Instructor 3">
      <h5>Guru Name</h5>
      <p>Specialist in Sound Healing</p>
    </div>
  </div>
</section>

<!-- Contact -->
<section id="contact" class="container my-5">
  <h2>Contact Us</h2>
  <form>
    <div class="mb-3"><input type="text" class="form-control" placeholder="Your Name"></div>
    <div class="mb-3"><input type="email" class="form-control" placeholder="Your Email"></div>
    <div class="mb-3"><textarea class="form-control" rows="4" placeholder="Message"></textarea></div>
    <button type="submit" class="btn btn-success">Send</button>
  </form>
</section>

<!-- Footer -->
<footer class="text-center">
  <p>&copy; 2026 Yogic Living | Connect with us on social media</p>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
